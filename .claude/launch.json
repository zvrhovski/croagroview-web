      "name": "landing",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),p=require('path'),f=p.join('C:/Users/Zoran/Desktop/croagroview-web',q.url==='/'?'index.html':q.url),e=p.extname(f),t={'.html':'text/html','.js':'text/javascript','.css':'text/css','.png':'image/png','.ico':'image/x-icon','.json':'application/json'}[e]||'application/octet-stream';fs.readFile(f,(err,d)=>{if(err){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':t});r.end(d)}})}).listen(3000,()=>console.log('Server on 3000'))"],
      "port": 3000
    }
  ]
